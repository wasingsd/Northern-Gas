generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  supabaseId     String?         @unique // links to Supabase auth.uid()
  name           String
  email          String          @unique
  password       String          @default("") // kept for migration safety; auth handled by Supabase
  role           String          @default("OWNER")
  createdAt      DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deliveryJobsAsDriver1 DeliveryJob[]   @relation("Driver1")
  deliveryJobsAsDriver2 DeliveryJob[]   @relation("Driver2")
  returnReceipts        ReturnReceipt[]
}

model Customer {
  id             String          @id @default(cuid())
  customerCode   String?         @unique
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  cylinders      Cylinder[]
  orders         Order[]
  returnReceipts ReturnReceipt[]
}

model Cylinder {
  id                 String              @id @default(cuid())
  cylinderNo         String              @unique
  qrCode             String              @unique
  status             String
  currentCustomerId  String?
  orderId            String?
  productId          String?
  ownerId            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  refillBatchId      String?
  refillBatch        RefillBatch?        @relation(fields: [refillBatchId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])
  currentCustomer    Customer?           @relation(fields: [currentCustomerId], references: [id])
  product            GasProduct?         @relation(fields: [productId], references: [id])
  owner              CylinderOwner?      @relation(fields: [ownerId], references: [id])
  logs               CylinderLog[]
  returnReceiptItems ReturnReceiptItem[]
}

model RefillBatch {
  id         String     @id @default(cuid())
  batchNo    String     @unique
  status     String     @default("SENT")
  sentAt     DateTime   @default(now())
  receivedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  cylinders  Cylinder[]
}

model CylinderLog {
  id         String   @id @default(cuid())
  cylinderId String
  status     String
  notes      String?
  createdAt  DateTime @default(now())
  cylinder   Cylinder @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
}

model Order {
  id          String       @id @default(cuid())
  orderNo     String       @unique
  customerId  String
  invoiceNo   String?
  status      String       @default("PENDING")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cylinders   Cylinder[]
  items       OrderItem[]
  deliveryJob DeliveryJob?
  customer    Customer     @relation(fields: [customerId], references: [id])
}

model DeliveryJob {
  id          String    @id @default(cuid())
  jobNo       String    @unique
  orderId     String    @unique
  driver1Id   String?
  driver1     User?     @relation("Driver1", fields: [driver1Id], references: [id])
  driver2Id   String?
  driver2     User?     @relation("Driver2", fields: [driver2Id], references: [id])
  status      String    @default("WAITING")
  address     String?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicleId   String?
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model GasProduct {
  id         String         @id @default(cuid())
  name       String
  size       String         @default("")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  cylinders  Cylinder[]
  orderItems OrderItem[]
}

model CylinderOwner {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  cylinders Cylinder[]
}

model OrderItem {
  id        String     @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   GasProduct @relation(fields: [productId], references: [id])
}

model ReturnReceipt {
  id         String   @id @default(cuid())
  receiptNo  String   @unique
  customerId String
  driverId   String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  customer Customer            @relation(fields: [customerId], references: [id])
  driver   User?               @relation(fields: [driverId], references: [id])
  vehicleId String?
  vehicle  Vehicle?            @relation(fields: [vehicleId], references: [id])
  items    ReturnReceiptItem[]
}

model ReturnReceiptItem {
  id              String @id @default(cuid())
  returnReceiptId String
  cylinderId      String

  returnReceipt ReturnReceipt @relation(fields: [returnReceiptId], references: [id], onDelete: Cascade)
  cylinder      Cylinder      @relation(fields: [cylinderId], references: [id])
}

model CompanyProfile {
  id        String   @id @default(cuid())
  nameEN    String
  nameTH    String
  addressEN String?
  addressTH String?
  tel1      String?
  tel2      String?
  fax       String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id             String          @id @default(cuid())
  registration   String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deliveryJobs   DeliveryJob[]
  returnReceipts ReturnReceipt[]
}
