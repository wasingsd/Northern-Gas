// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("OWNER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deliveryJobs DeliveryJob[]
}

model Customer {
  id           String   @id @default(cuid())
  customerCode String?  @unique
  name         String
  taxType      String   @default("UNSPECIFIED") // UNSPECIFIED, INDIVIDUAL, CORPORATE
  taxId        String?
  branchName   String?
  branchNo     String?
  phone        String?
  email        String?
  lineId       String?
  address      String?
  lat          Float?
  lng          Float?
  type         String   @default("GENERAL") // GENERAL, B2B
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  cylinders    Cylinder[]
}

model GasProduct {
  id           String   @id @default(cuid())
  name         String
  sizeKg       Float
  salePrice    Float
  deliveryFee  Float
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orderItems   OrderItem[]
  cylinders    Cylinder[]
}

model Cylinder {
  id                String       @id @default(cuid())
  assetCode         String       @unique
  qrCode            String       @unique
  status            String       // READY_TO_DISPATCH, WITH_CUSTOMER, etc.
  
  productId         String?
  product           GasProduct?  @relation(fields: [productId], references: [id])
  
  currentCustomerId String?
  currentCustomer   Customer?    @relation(fields: [currentCustomerId], references: [id])
  
  orderId           String?
  order             Order?       @relation(fields: [orderId], references: [id])
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  logs              CylinderLog[]
  refillBatchId     String?
  refillBatch       RefillBatch? @relation(fields: [refillBatchId], references: [id])
}

model RefillBatch {
  id          String   @id @default(cuid())
  batchNo     String   @unique
  status      String   @default("SENT") // SENT, RECEIVED
  sentAt      DateTime @default(now())
  receivedAt  DateTime?
  totalCost   Float    @default(0)
  cylinders   Cylinder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CylinderLog {
  id          String   @id @default(cuid())
  cylinderId  String
  cylinder    Cylinder @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
  status      String
  notes       String?
  createdAt   DateTime @default(now())
}

model Order {
  id            String   @id @default(cuid())
  orderNo       String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  totalAmount   Float
  paymentStatus String   @default("UNPAID") // UNPAID, PAID
  items         OrderItem[]
  cylinders     Cylinder[]
  deliveryJob   DeliveryJob?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     GasProduct @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  totalPrice  Float
}

model DeliveryJob {
  id          String   @id @default(cuid())
  jobNo       String   @unique
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverId    String?
  driver      User?    @relation(fields: [driverId], references: [id])
  status      String   @default("WAITING") // WAITING, ASSIGNED, OUT_FOR_DELIVERY, DELIVERED
  address     String?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
