generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  supabaseId   String?       @unique // links to Supabase auth.uid()
  name         String
  email        String        @unique
  password     String        @default("") // kept for migration safety; auth handled by Supabase
  role         String        @default("OWNER")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deliveryJobs DeliveryJob[]
}

model Customer {
  id           String     @id @default(cuid())
  customerCode String?    @unique
  name         String
  taxType      String     @default("UNSPECIFIED")
  taxId        String?
  branchName   String?
  branchNo     String?
  phone        String?
  email        String?
  lineId       String?
  address      String?
  lat          Float?
  lng          Float?
  type         String     @default("GENERAL")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  cylinders    Cylinder[]
  orders       Order[]
}

model Cylinder {
  id                String        @id @default(cuid())
  cylinderNo        String        @unique
  qrCode            String        @unique
  cylinderCode      String?
  status            String
  currentCustomerId String?
  orderId           String?
  productId         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  refillBatchId     String?
  refillBatch       RefillBatch?  @relation(fields: [refillBatchId], references: [id])
  order             Order?        @relation(fields: [orderId], references: [id])
  currentCustomer   Customer?     @relation(fields: [currentCustomerId], references: [id])
  product           GasProduct?   @relation(fields: [productId], references: [id])
  logs              CylinderLog[]
}

model RefillBatch {
  id         String     @id @default(cuid())
  batchNo    String     @unique
  status     String     @default("SENT")
  sentAt     DateTime   @default(now())
  receivedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  cylinders  Cylinder[]
}

model CylinderLog {
  id         String   @id @default(cuid())
  cylinderId String
  status     String
  notes      String?
  createdAt  DateTime @default(now())
  cylinder   Cylinder @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
}

model Order {
  id          String       @id @default(cuid())
  orderNo     String       @unique
  customerId  String
  status      String       @default("PENDING")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cylinders   Cylinder[]
  items       OrderItem[]
  deliveryJob DeliveryJob?
  customer    Customer     @relation(fields: [customerId], references: [id])
}

model DeliveryJob {
  id          String    @id @default(cuid())
  jobNo       String    @unique
  orderId     String    @unique
  driverId    String?
  status      String    @default("WAITING")
  address     String?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  driver      User?     @relation(fields: [driverId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model GasProduct {
  id          String       @id @default(cuid())
  name        String
  sizeKg      Float
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cylinders   Cylinder[]
  orderItems  OrderItem[]
}

model OrderItem {
  id          String     @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     GasProduct @relation(fields: [productId], references: [id])
}
